# 🔐 LOCAL SECRETS TEMPLATE
# This file is for LOCAL development only
# DO NOT COMMIT THIS FILE - it's in .gitignore
#
# Instructions:
# 1. Copy this file: cp .env.secrets .env.local
# 2. Fill in YOUR actual values below
# 3. Use .env.local for local testing

# Anthropic API Key
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-PASTE_YOUR_KEY_HERE

# Gmail OAuth Credentials
# See SETUP_SECRETS.md for detailed instructions

# Get GMAIL_CLIENT_ID and GMAIL_CLIENT_SECRET from:
# https://console.cloud.google.com → APIs & Services → Credentials
GMAIL_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-YOUR_SECRET_HERE

# Get GMAIL_REFRESH_TOKEN by running the OAuth flow:
# See SETUP_SECRETS.md → "Step 4: Generate Refresh Token"
GMAIL_REFRESH_TOKEN=YOUR_REFRESH_TOKEN_HERE

# GitHub Token (for adding secrets via script)
# Create at: https://github.com/settings/tokens
# Required scopes: repo (full control)
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# Optional: Debug mode
DEBUG=false
LOG_LEVEL=INFO
